from core.test import { test, reset, summary };
import core.bit as bit;

[[test("tests.bit_intrinsics corpus")]]
fn corpus() {
    reset();

    test("bit_and", bit.and(6, 3) == 2);
    test("bit_or", bit.or(6, 3) == 7);
    test("bit_xor", bit.xor(6, 3) == 5);
    test("bit_not", bit.not(0) == -1);
    test("bit_shl", bit.shl(1, 5) == 32);
    test("bit_shr", bit.shr(32, 5) == 1);
    test("bit_shr_unsigned", bit.shr(-1, 1) == 2147483647);
    test("bit_shl_high_bit", bit.shl(1, 31) == bit.not(2147483647));

    summary();
}
