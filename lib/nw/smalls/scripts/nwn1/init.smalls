    mfeat.add(Const.mfeat_spell_focus_greater, Const.spell_school_evocation, Const.feat_greater_spell_focus_evocation);
    mfeat.add(Const.mfeat_spell_focus_greater, Const.spell_school_illusion, Const.feat_greater_spell_focus_illusion);
    mfeat.add(Const.mfeat_spell_focus_greater, Const.spell_school_necromancy, Const.feat_greater_spell_focus_necromancy);
    mfeat.add(Const.mfeat_spell_focus_greater, Const.spell_school_transmutation, Const.feat_greater_spell_focus_transmutation);

    mfeat.add(Const.mfeat_spell_focus_epic, Const.spell_school_abjuration, Const.feat_epic_spell_focus_abjuration);
    mfeat.add(Const.mfeat_spell_focus_epic, Const.spell_school_conjuration, Const.feat_epic_spell_focus_conjuration);
    mfeat.add(Const.mfeat_spell_focus_epic, Const.spell_school_divination, Const.feat_epic_spell_focus_divination);
    mfeat.add(Const.mfeat_spell_focus_epic, Const.spell_school_enchantment, Const.feat_epic_spell_focus_enchantment);
    mfeat.add(Const.mfeat_spell_focus_epic, Const.spell_school_evocation, Const.feat_epic_spell_focus_evocation);
    mfeat.add(Const.mfeat_spell_focus_epic, Const.spell_school_illusion, Const.feat_epic_spell_focus_illusion);
    mfeat.add(Const.mfeat_spell_focus_epic, Const.spell_school_necromancy, Const.feat_epic_spell_focus_necromancy);
    mfeat.add(Const.mfeat_spell_focus_epic, Const.spell_school_transmutation, Const.feat_epic_spell_focus_transmutation);

    mfeat.set_bonus(Const.mfeat_weapon_focus, 1);
    mfeat.set_bonus(Const.mfeat_weapon_focus_epic, 2);
    mfeat.set_bonus(Const.mfeat_weapon_spec, 2);
    mfeat.set_bonus(Const.mfeat_weapon_spec_epic, 4);
    // [TODO] One here is just an indicator that char has feat.. for now.  Ultimately, dice rolls
    // and damage rolls will need to be included in ModifierResult
    mfeat.set_bonus(Const.mfeat_devastating_crit, 1);
    mfeat.set_bonus(Const.mfeat_improved_crit, 1);
    mfeat.set_bonus(Const.mfeat_overwhelming_crit, 1);
    mfeat.set_bonus(Const.mfeat_weapon_of_choice, 1);

    mfeat.add(Const.mfeat_weapon_focus, BaseItemType(-1), Const.feat_weapon_focus_unarmed);
    mfeat.add(Const.mfeat_weapon_focus_epic, BaseItemType(-1), Const.feat_epic_weapon_focus_unarmed);
    mfeat.add(Const.mfeat_weapon_spec, BaseItemType(-1), Const.feat_weapon_specialization_unarmed);
    mfeat.add(Const.mfeat_weapon_spec_epic, BaseItemType(-1), Const.feat_epic_devastating_critical_unarmed);
    mfeat.add(Const.mfeat_devastating_crit, BaseItemType(-1), Const.feat_epic_devastating_critical_unarmed);
    mfeat.add(Const.mfeat_improved_crit, BaseItemType(-1), Const.feat_improved_critical_unarmed);
    mfeat.add(Const.mfeat_overwhelming_crit, BaseItemType(-1), Const.feat_epic_overwhelming_critical_unarmed);

}

fn init() {
    if (did_init) { return; }
    did_init = true;

    nwn1effects.register_effect_types();
    nwn1item.register_default_generators();
    init_combat_modes();
    init_special_attacks();
    init_modifiers();
    init_master_feats();
}
