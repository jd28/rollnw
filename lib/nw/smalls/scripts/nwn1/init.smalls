var did_init = false;

fn attack_bonus_epic_prowess(obj: Creature, subtype: Const.AttackType): int {
    if (subtype != Const.attack_type_any) { return 0; }
    return Cre.has_feat(obj, Const.feat_epic_prowess) ? 1 : 0;
}

fn attack_bonus_target_state(obj: Creature, versus: object, subtype: Const.AttackType): int {
    const target_state_blind = 1;
    const target_state_attacker_invis = 2;
    const target_state_unseen = 4;
    const target_state_stunned = 32;
    const target_state_flanked = 64;
    const target_state_invis = 1024;

    if (subtype != Const.attack_type_any) {
        return 0;
    }
    if (!(versus is Creature)) {
        return 0;
    }

    var result = 0;
    var combat = get_propset!(CreatureCombat)(obj);
    var vs = versus as Creature;

    if (bit.and(combat.target_state, target_state_attacker_invis) != 0
        || bit.and(combat.target_state, target_state_blind) != 0) {
        if (!Cre.has_feat(vs, Const.feat_blind_fight)) {
            result += 2;
        }
    }

    if (bit.and(combat.target_state, target_state_stunned) != 0) {
        result += 2;
    }

    if (bit.and(combat.target_state, target_state_flanked) != 0) {
        if (!Cre.has_feat(vs, Const.feat_prestige_defensive_awareness_2)) {
            result += 2;
        }
    }

    if (bit.and(combat.target_state, target_state_unseen) != 0
        || bit.and(combat.target_state, target_state_invis) != 0) {
        result -= 4;
    }

    return result;
}

fn attack_bonus_training_versus(obj: Creature, versus: object, subtype: Const.AttackType): int {
    if (subtype != Const.attack_type_any) {
        return 0;
    }
    if (!(versus is Creature)) {
        return 0;
    }

    var vs_stats = get_propset!(CreatureStats)(versus as Creature);
    var race = Const.RacialType(vs_stats.race);
    if (race == Const.racial_type_humanoid_goblinoid
        && Cre.has_feat(obj, Const.feat_battle_training_versus_goblins)) {
        return 1;
    }
    if (race == Const.racial_type_humanoid_orc
        && Cre.has_feat(obj, Const.feat_battle_training_versus_orcs)) {
        return 1;
    }
    if (race == Const.racial_type_humanoid_reptilian
        && Cre.has_feat(obj, Const.feat_battle_training_versus_reptilians)) {
        return 1;
    }

    return 0;
}

fn attack_bonus_favored_enemy(obj: Creature, versus: object, subtype: Const.AttackType): int {
    if (subtype != Const.attack_type_any || !(versus is Creature)) { return 0; }
    const ranger = Cre.get_level_by_class(obj, Const.class_type_ranger);
    if (ranger == 0) { return 0; }

    const ps = get_propset!(CreatureStats)(versus as Creature);
    const check = mfeat.resolve(obj, Const.mfeat_favored_enemy, Const.RacialType(ps.race));

    var result = 0;
    if (check > 0) {
        result = 1 + ranger / 5;
        if(Cre.has_feat(obj, Const.feat_epic_bane_of_enemies)) {
            result += 2;
        }
    }
    return result;
}

fn attack_bonus_combat_mode(obj: Creature, subtype: Const.AttackType): int {
    if (subtype != Const.attack_type_any) { return 0; }
    var combat = get_propset!(CreatureCombat)(obj);
    return combat_modes.attack_bonus_modifier(combat.combat_mode, obj);
}

// Wrapper functions to match register_attack_bonus_modifier signature
fn _ab_epic_prowess(obj: Creature, _vs: object, subtype: Const.AttackType): int {
    return attack_bonus_epic_prowess(obj, subtype);
}

fn _ab_combat_mode(obj: Creature, _vs: object, subtype: Const.AttackType): int {
    return attack_bonus_combat_mode(obj, subtype);
}

fn _mode_damage_none(_obj: Creature, _multiplier: int): int {
    return 0;
}

fn _mode_ac_none(_obj: Creature): int {
    return 0;
}

fn _mode_can_use_always(_obj: Creature): bool {
    return true;
}

fn _mode_apply_none(_obj: Creature) {
}

fn _mode_remove_none(_obj: Creature) {
}

fn _mode_bonus_minus_2(_obj: Creature): int {
    return -2;
}

fn _mode_bonus_minus_5(_obj: Creature): int {
    return -5;
}

fn _mode_bonus_minus_10(_obj: Creature): int {
    return -10;
}

fn _mode_ac_plus_5(_obj: Creature): int {
    return 5;
}

fn _mode_ac_plus_10(_obj: Creature): int {
    return 10;
}

fn _mode_damage_plus_5(_obj: Creature, multiplier: int): int {
    return 5 * multiplier;
}

fn _mode_damage_plus_10(_obj: Creature, multiplier: int): int {
    return 10 * multiplier;
}

fn _is_monk_weapon_base_item(base_item: BaseItemType): bool {
    if (base_item == Const.base_item_invalid) {
        return true;
    }
    return base_item == Const.base_item_kama
        || base_item == Const.base_item_quarterstaff
        || base_item == Const.base_item_shuriken
        || base_item == Const.base_item_gloves
        || base_item == Const.base_item_bracer;
}

fn _is_ranged_weapon_base_item(base_item: BaseItemType): bool {
    return base_item == Const.base_item_longbow
        || base_item == Const.base_item_shortbow
        || base_item == Const.base_item_lightcrossbow
        || base_item == Const.base_item_heavycrossbow
        || base_item == Const.base_item_sling
        || base_item == Const.base_item_dart
        || base_item == Const.base_item_shuriken
        || base_item == Const.base_item_throwingaxe;
}

fn _mode_can_use_flurry(obj: Creature): bool {
    var rh = Item.get_baseitem_type(Cre.get_equipped_item(obj, Const.equip_index_righthand));
    var lh = Item.get_baseitem_type(Cre.get_equipped_item(obj, Const.equip_index_lefthand));
    return _is_monk_weapon_base_item(rh) && _is_monk_weapon_base_item(lh);
}

fn _mode_can_use_rapid_shot(obj: Creature): bool {
    var rh = Item.get_baseitem_type(Cre.get_equipped_item(obj, Const.equip_index_righthand));
    return _is_ranged_weapon_base_item(rh);
}

fn _register_combat_mode(
    mode: int,
    attack_bonus_modifier: fn(Creature): int,
    damage_bonus_modifier: fn(Creature, int): int,
    armor_class_modifier: fn(Creature): int,
    can_use: fn(Creature): bool,
    apply: fn(Creature),
    remove: fn(Creature),
) {
    var modes: array!(int) = {};
    arr.push(modes, mode);
    combat_modes.register_combat_mode(
        modes,
        attack_bonus_modifier,
        damage_bonus_modifier,
        armor_class_modifier,
        can_use,
        apply,
        remove);
}

fn _special_attack_damage_none(_obj: Creature, _target: object, _multiplier: int): int {
    return 0;
}

fn _special_attack_impact_none(_obj: Creature, _target: object): effects.Effect {
    return effects.invalid();
}

fn _special_attack_can_use_good(_obj: Creature, target: object): bool {
    if (target is Creature) {
        var stats = get_propset!(CreatureStats)(target);
        return stats.good_evil > 50;
    }
    return false;
}

fn _special_attack_can_use_evil(_obj: Creature, target: object): bool {
    if (target is Creature) {
        var stats = get_propset!(CreatureStats)(target);
        return stats.good_evil < 50;
    }
    return false;
}

fn _special_attack_ab_smite_good(obj: Creature, _target: object): int {
    var level = Cre.get_level_by_class(obj, Const.class_type_blackguard);
    if (level <= 0) {
        return 0;
    }
    return NCre.get_ability_score(obj, Const.ability_charisma);
}

fn _special_attack_ab_smite_evil(obj: Creature, _target: object): int {
    var level = Cre.get_level_by_class(obj, Const.class_type_paladin)
        + Cre.get_level_by_class(obj, Const.class_type_divinechampion);
    if (level <= 0) {
        return 0;
    }
    return NCre.get_ability_score(obj, Const.ability_charisma);
}

fn _register_special_attack(
    attack_type_id: int,
    attack_bonus_modifier: fn(Creature, object): int,
    damage_bonus_modifier: fn(Creature, object, int): int,
    usable: fn(Creature, object): bool,
    impact: fn(Creature, object): effects.Effect,
) {
    var attack_types: array!(int) = {};
    arr.push(attack_types, attack_type_id);
    special_attack.register_special_attack(
        attack_types,
        attack_bonus_modifier,
        damage_bonus_modifier,
        usable,
        impact);
}

fn init_special_attacks() {
    _register_special_attack(
        Const.special_attack_smite_good,
        _special_attack_ab_smite_good,
        _special_attack_damage_none,
        _special_attack_can_use_good,
        _special_attack_impact_none);

    _register_special_attack(
        Const.special_attack_smite_evil,
        _special_attack_ab_smite_evil,
        _special_attack_damage_none,
        _special_attack_can_use_evil,
        _special_attack_impact_none);
}

fn init_combat_modes() {
    _register_combat_mode(Const.combat_mode_expertise,
        _mode_bonus_minus_5, _mode_damage_none, _mode_ac_plus_5,
        _mode_can_use_always, _mode_apply_none, _mode_remove_none);
    _register_combat_mode(Const.combat_mode_improved_expertise,
        _mode_bonus_minus_10, _mode_damage_none, _mode_ac_plus_10,
        _mode_can_use_always, _mode_apply_none, _mode_remove_none);

    _register_combat_mode(Const.combat_mode_power_attack,
        _mode_bonus_minus_5, _mode_damage_plus_5, _mode_ac_none,
        _mode_can_use_always, _mode_apply_none, _mode_remove_none);
    _register_combat_mode(Const.combat_mode_improved_power_attack,
        _mode_bonus_minus_10, _mode_damage_plus_10, _mode_ac_none,
        _mode_can_use_always, _mode_apply_none, _mode_remove_none);

    _register_combat_mode(Const.combat_mode_flurry_of_blows,
        _mode_bonus_minus_2, _mode_damage_none, _mode_ac_none,
        _mode_can_use_flurry, _mode_apply_none, _mode_remove_none);
    _register_combat_mode(Const.combat_mode_rapid_shot,
        _mode_bonus_minus_2, _mode_damage_none, _mode_ac_none,
        _mode_can_use_rapid_shot, _mode_apply_none, _mode_remove_none);
}

fn dragon_disciple_ability(obj: Creature, _vs: object, subtype: int): int {
    const st = Const.Ability(subtype);
    const rdd_level = Cre.get_level_by_class(obj, Const.class_type_dragon_disciple);
    if (rdd_level == 0) { return 0; }

    if (st == Const.ability_strength) {
        if (rdd_level >= 10) { return 8; }
        elif (rdd_level >= 4) { return 4; }
        elif (rdd_level >= 2) { return 2; }
    } elif (st == Const.ability_constitution) {
        if (rdd_level >= 5) { return 2; }
    } elif (st == Const.ability_intelligence) {
        if (rdd_level >= 9) { return 2; }
    } elif (st == Const.ability_charisma) {
        if (rdd_level >= 10) { return 2; }
    }

    return 0;
}

fn epic_great_ability(obj: Creature, _vs: object, subtype: int): int {
    const st = Const.Ability(subtype);
    if (st == Const.ability_strength) {
        return ranked_feat_count(obj, Const.feat_epic_great_strength_1, Const.feat_epic_great_strength_10);
    } elif (st == Const.ability_dexterity) {
        return ranked_feat_count(obj, Const.feat_epic_great_dexterity_1, Const.feat_epic_great_dexterity_10);
    } elif (st == Const.ability_constitution) {
        return ranked_feat_count(obj, Const.feat_epic_great_constitution_1, Const.feat_epic_great_constitution_10);
    } elif (st == Const.ability_intelligence) {
        return ranked_feat_count(obj, Const.feat_epic_great_intelligence_1, Const.feat_epic_great_intelligence_10);
    } elif (st == Const.ability_wisdom) {
        return ranked_feat_count(obj, Const.feat_epic_great_wisdom_1, Const.feat_epic_great_wisdom_10);
    } elif (st == Const.ability_charisma) {
        return ranked_feat_count(obj, Const.feat_epic_great_charisma_1, Const.feat_epic_great_charisma_10);
    }
    return 0;
}

fn ranked_feat_count(obj: Creature, start: Feat, stop: Feat): int {
    var highest = Cre.highest_feat_in_range(obj, start, stop);
    if (highest as int < 0) {
        return 0;
    }
    var highest_id = highest as int;
    var start_id = start as int;
    return highest_id - start_id + 1;
}

const NUM_SLOTS = 31;

type SlotPayload {
    slot: int;
    mask: int;
};

// Slot dependency definitions - single source of truth for slot_depends_on initialization
// Each entry maps a slot constant to its invalidation mask
const SLOT_DEPENDENCIES: array!(SlotPayload) = {
    // Offense slots: non-target dependent (0-4)
    {slot = slot_off_ab_nt_onhand,  mask = bit.or(key_equipment_epoch, bit.or(key_progression_epoch, key_mode_epoch))},
    {slot = slot_off_ab_nt_offhand, mask = bit.or(key_equipment_epoch, bit.or(key_progression_epoch, key_mode_epoch))},
    {slot = slot_off_ab_nt_cweapon, mask = bit.or(key_equipment_epoch, bit.or(key_progression_epoch, key_mode_epoch))},
    {slot = slot_off_ab_nt_unarmed, mask = bit.or(key_equipment_epoch, bit.or(key_progression_epoch, key_mode_epoch))},
    {slot = slot_off_ab_nt_any,     mask = bit.or(key_equipment_epoch, bit.or(key_progression_epoch, key_mode_epoch))},
    // Offense slots: target dependent (5)
    {slot = slot_off_ab_t_any,      mask = bit.or(key_target_id, bit.or(key_self_effect_epoch, key_target_effect_epoch))},
    // Defense slots (6-15)
    {slot = slot_def_ac_nt_base,      mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_def_ac_nt_mode_size, mask = bit.or(key_mode_epoch, key_progression_epoch)},
    {slot = slot_def_ac_nt_misc,      mask = bit.or(key_self_effect_epoch, key_progression_epoch)},
    {slot = slot_def_ac_t_any,        mask = bit.or(key_target_id, bit.or(key_self_effect_epoch, key_target_effect_epoch))},
    {slot = slot_def_ac_t_melee,      mask = bit.or(key_target_id, bit.or(key_self_effect_epoch, key_target_effect_epoch))},
    {slot = slot_def_ac_t_ranged,     mask = bit.or(key_target_id, bit.or(key_self_effect_epoch, key_target_effect_epoch))},
    {slot = slot_def_conceal_t_melee,      mask = bit.or(key_target_id, bit.or(key_self_effect_epoch, key_target_effect_epoch))},
    {slot = slot_def_conceal_t_ranged,     mask = bit.or(key_target_id, bit.or(key_self_effect_epoch, key_target_effect_epoch))},
    {slot = slot_def_miss_chance_t_melee,  mask = bit.or(key_target_id, bit.or(key_self_effect_epoch, key_target_effect_epoch))},
    {slot = slot_def_miss_chance_t_ranged, mask = bit.or(key_target_id, bit.or(key_self_effect_epoch, key_target_effect_epoch))},
    // Per-round stable offense caches (16-27): invalidated by equipment or progression only
    {slot = slot_off_bab,              mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_feat_flags,       mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_dual_wield_on,    mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_dual_wield_off,   mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_crit_threat_on,   mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_crit_threat_off,  mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_weapon_iter_on,   mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_weapon_iter_off,  mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_weapon_power_on,  mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_weapon_power_off, mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_monk_power,       mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_enchant_arrow,    mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_attack_type_mask, mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_damage_mask_on,   mask = bit.or(key_equipment_epoch, key_progression_epoch)},
    {slot = slot_off_damage_mask_off,  mask = bit.or(key_equipment_epoch, key_progression_epoch)},
};

// == Armor Class Modifiers =================================================
fn ac_modifier_dragon_disciple_natural(obj: Creature, _vs: object, subtype: int): int {
    var level = Cre.get_level_by_class(obj, Const.class_type_dragon_disciple);
    if (level >= 10) {
        return (level / 5) + 2;
    } elif (level >= 8) {
        return 3;
    } elif (level >= 5) {
        return 2;
    } elif (level >= 1) {
        return 1;
    }
    return 0;
}

fn ac_modifier_pale_master_natural(obj: Creature, _vs: object, subtype: int): int {
    var pm_level = Cre.get_level_by_class(obj, Const.class_type_pale_master);
    if (pm_level > 0) {
        return ((pm_level / 4) + 1) * 2;
    }
    return 0;
}

fn ac_modifier_epic_armor_skin(obj: Creature, _vs: object, subtype: int): int {
    if (Cre.has_feat(obj, Const.feat_epic_armor_skin)) { return 2; }
    return 0;
}

fn ac_modifier_tumble_dodge(obj: Creature, _vs: object, subtype: int): int {
    var stats = get_propset!(CreatureStats)(obj);
    return stats.skills[Const.skill_tumble as int] / 5;
}

fn ac_modifier_combat_mode_dodge(obj: Creature, _vs: object, subtype: int): int {
    var combat = get_propset!(CreatureCombat)(obj);
    return combat_modes.armor_class_modifier(combat.combat_mode, obj);
}

fn ac_modifier_training_vs_giants(obj: Creature, vs: object, subtype: int): int {
    if (!Cre.has_feat(obj, Const.feat_battle_training_versus_giants)) { return 0; }
    if (vs is Creature) {
        var vs_stats = get_propset!(CreatureStats)(vs);
        if (vs_stats.race == Const.racial_type_giant as int) { return 4; }
    }
    return 0;
}

// == Concealment Modifiers =================================================
fn concealment_modifier_epic_self(obj: Creature, _vs: object, _subtype: int): int {
    var nth = Cre.highest_feat_in_range(obj, Const.feat_epic_self_concealment_10, Const.feat_epic_self_concealment_50);
    if (nth as int >= 0) {
        return ((nth as int) - (Const.feat_epic_self_concealment_10 as int) + 1) * 10;
    }
    return 0;
}

// == Hitpoints Modifiers ===================================================
fn hp_modifier_toughness(obj: Creature, _vs: object, _subtype: int): int {
    if (Cre.has_feat(obj, Const.feat_toughness)) {
        return Cre.get_total_levels(obj);
    }
    return 0;
}

fn hp_modifier_epic_toughness(obj: Creature, _vs: object, _subtype: int): int {
    return ranked_feat_count(obj, Const.feat_epic_toughness_1, Const.feat_epic_toughness_10) * 20;
}

// == Damage Reduction Modifiers =============================================
fn dr_modifier_barbarian(obj: Creature, _vs: object, _subtype: int): int {
    var barb = Cre.get_level_by_class(obj, Const.class_type_barbarian);
    if (barb > 10) {
        return 1 + (barb - 10) / 3;
    }
    return 0;
}

fn dr_modifier_dwarven_defender(obj: Creature, _vs: object, _subtype: int): int {
    var dd = Cre.get_level_by_class(obj, Const.class_type_dwarven_defender);
    if (dd > 0) {
        return 3 + ((dd - 6) / 4 * 3);
    }
    return 0;
}

fn dr_modifier_epic(obj: Creature, _vs: object, _subtype: int): int {
    if (Cre.has_feat(obj, Const.feat_epic_damage_reduction_9)) { return 9; }
    elif (Cre.has_feat(obj, Const.feat_epic_damage_reduction_6)) { return 6; }
    elif (Cre.has_feat(obj, Const.feat_epic_damage_reduction_3)) { return 3; }
    return 0;
}

// == Damage Resistance Modifiers ============================================
fn resistance_modifier_energy(obj: Creature, _vs: object, subtype: int): int {
    var start = -1;
    var stop = -1;
    var base_feat = -1;
    if (subtype == Const.damage_type_acid as int) {
        start = Const.feat_epic_energy_resistance_acid_1 as int;
        stop = Const.feat_epic_energy_resistance_acid_10 as int;
        base_feat = Const.feat_resist_energy_acid as int;
    } elif (subtype == Const.damage_type_cold as int) {
        start = Const.feat_epic_energy_resistance_cold_1 as int;
        stop = Const.feat_epic_energy_resistance_cold_10 as int;
        base_feat = Const.feat_resist_energy_cold as int;
    } elif (subtype == Const.damage_type_electrical as int) {
        start = Const.feat_epic_energy_resistance_electrical_1 as int;
        stop = Const.feat_epic_energy_resistance_electrical_10 as int;
        base_feat = Const.feat_resist_energy_electrical as int;
    } elif (subtype == Const.damage_type_fire as int) {
        start = Const.feat_epic_energy_resistance_fire_1 as int;
        stop = Const.feat_epic_energy_resistance_fire_10 as int;
        base_feat = Const.feat_resist_energy_fire as int;
    } elif (subtype == Const.damage_type_sonic as int) {
        start = Const.feat_epic_energy_resistance_sonic_1 as int;
        stop = Const.feat_epic_energy_resistance_sonic_10 as int;
        base_feat = Const.feat_resist_energy_sonic as int;
    } else {
        return 0;
    }
    var nth = Cre.highest_feat_in_range(obj, Const.Feat(start), Const.Feat(stop));
    if (nth as int >= 0) {
        return ((nth as int) - start + 1) * 10;
    } elif (Cre.has_feat(obj, Const.Feat(base_feat))) {
        return 5;
    }
    return 0;
}

// == Ability Modifiers =====================================================
fn ability_modifier_epic_great(obj: Creature, _vs: object, subtype: int): int {
    return epic_great_ability(obj, _vs, subtype);
}

fn ability_modifier_dragon_disciple(obj: Creature, _vs: object, subtype: int): int {
    return dragon_disciple_ability(obj, _vs, subtype);
}

// == Skill Modifiers =======================================================
fn skill_modifier_stonecunning_search(obj: Creature, _vs: object, subtype: int): int {
    if (subtype != Const.skill_search as int) { return 0; }
    if (Cre.has_feat(obj, Const.feat_stonecunning)) { return 2; }
    return 0;
}

fn init_modifiers() {
    // == Slot system: slot_depends_on ========================================
    // Initialize from SLOT_DEPENDENCIES table (single source of truth)
    for (var def in SLOT_DEPENDENCIES) {
        arr.push(modifier.slot_depends_on, def.mask);
    }

    // Runtime assertion: ensure SLOT_DEPENDENCIES count matches expected slots
    if (arr.len(modifier.slot_depends_on) != NUM_SLOTS) {
        panic(f"Slot dependency count mismatch: expected {NUM_SLOTS} but got {arr.len(modifier.slot_depends_on)}");
    }

    // == Ability =============================================================
    modifier.register_modifier(Const.mod_type_ability, "epic_great_ability", ability_modifier_epic_great, -1);
    modifier.register_modifier(Const.mod_type_ability, "dragon_disciple_ability", ability_modifier_dragon_disciple, -1);

    // == Armor Class =========================================================
    modifier.register_modifier(Const.mod_type_armor_class, "dragon_disciple_natural", ac_modifier_dragon_disciple_natural, Const.ac_natural as int);
    modifier.register_modifier(Const.mod_type_armor_class, "pale_master_natural", ac_modifier_pale_master_natural, Const.ac_natural as int);
    modifier.register_modifier(Const.mod_type_armor_class, "epic_armor_skin", ac_modifier_epic_armor_skin, Const.ac_natural as int);
    modifier.register_modifier(Const.mod_type_armor_class, "tumble_dodge", ac_modifier_tumble_dodge, Const.ac_dodge as int);
    modifier.register_modifier(Const.mod_type_armor_class, "combat_mode_dodge", ac_modifier_combat_mode_dodge, Const.ac_dodge as int);
    modifier.register_modifier(Const.mod_type_armor_class, "training_vs_giants", ac_modifier_training_vs_giants, Const.ac_natural as int);

    // == Concealment =========================================================
    modifier.register_modifier(Const.mod_type_concealment, "epic_self_concealment", concealment_modifier_epic_self, -1);

    // == Attack Bonus ========================================================
    modifier.register_attack_bonus_modifier("attack_bonus_epic_prowess",
        _ab_epic_prowess, -1,
        bit.or(scope_attack_any, inv_progression_epoch));

    // Target-sensitive AB modifiers already have correct signature
    modifier.register_attack_bonus_modifier("attack_bonus_target_state",
        attack_bonus_target_state, -1,
        bit.or(dep_target, bit.or(scope_attack_any,
                   bit.or(inv_target_change, inv_self_effect_epoch))));

    modifier.register_attack_bonus_modifier("attack_bonus_training_versus",
        attack_bonus_training_versus, -1,
        bit.or(dep_target, bit.or(scope_attack_any, inv_target_change)));

    modifier.register_attack_bonus_modifier("attack_bonus_favored_enemy",
        attack_bonus_favored_enemy, -1,
        bit.or(dep_target, bit.or(scope_attack_any, inv_target_change)));

    modifier.register_attack_bonus_modifier("attack_bonus_combat_mode",
        _ab_combat_mode, -1,
        bit.or(scope_attack_any, inv_mode_epoch));

    // == Build slot_buckets (only for AB slots 0-5) ==========================
    const NUM_AB_SLOTS = 6;
    var i = 0;
    for (i < NUM_AB_SLOTS) {
        var empty_bucket: array!(fn(Creature, object, Const.AttackType): int);
        arr.push(modifier.slot_buckets, empty_bucket);
        i += 1;
    }

    for (var ab_mod in modifier.attack_bonus_modifiers) {
        if (bit.and(ab_mod.meta_flags, dep_target) != 0) {
            arr.push(modifier.slot_buckets[slot_off_ab_t_any], ab_mod.payload);
        } elif (bit.and(ab_mod.meta_flags, scope_attack_any) != 0) {
            arr.push(modifier.slot_buckets[slot_off_ab_nt_any], ab_mod.payload);
        } else {
            arr.push(modifier.slot_buckets[slot_off_ab_nt_onhand], ab_mod.payload);
            arr.push(modifier.slot_buckets[slot_off_ab_nt_offhand], ab_mod.payload);
            arr.push(modifier.slot_buckets[slot_off_ab_nt_cweapon], ab_mod.payload);
            arr.push(modifier.slot_buckets[slot_off_ab_nt_unarmed], ab_mod.payload);
        }
    }

    // == Build slot invalidation LUTs =========================================
    // off_clear_lut[key_bits] = bitmask of offense slots (0-5) to clear when
    // changed_key_mask has those bits set (key_bits = changed_key_mask >> 8).
    // def_clear_lut[key_bits] = bitmask of defense slots (6-15) to clear.
    for (var key_bits = 0; key_bits < 128; key_bits += 1) {
        var changed = bit.shl(key_bits, 8);
        var off_bits = 0;
        for (var si = 0; si < NUM_AB_SLOTS; si += 1) {
            if (bit.and(modifier.slot_depends_on[si], changed) != 0) {
                off_bits = bit.or(off_bits, bit.shl(1, si));
            }
        }
        arr.push(modifier.off_clear_lut, off_bits);
        var def_bits = 0;
        for (var di = 6; di < 16; di += 1) {
            if (bit.and(modifier.slot_depends_on[di], changed) != 0) {
                def_bits = bit.or(def_bits, bit.shl(1, di));
            }
        }
        arr.push(modifier.def_clear_lut, def_bits);
    }

    // == Hitpoints ===========================================================
    modifier.register_modifier(Const.mod_type_hitpoints, "toughness", hp_modifier_toughness, -1);
    modifier.register_modifier(Const.mod_type_hitpoints, "epic_toughness", hp_modifier_epic_toughness, -1);

    // == Damage Reduction ====================================================
    modifier.register_modifier(Const.mod_type_dmg_reduction, "barbarian", dr_modifier_barbarian, -1);
    modifier.register_modifier(Const.mod_type_dmg_reduction, "dwarven_defender", dr_modifier_dwarven_defender, -1);
    modifier.register_modifier(Const.mod_type_dmg_reduction, "epic", dr_modifier_epic, -1);

    // == Damage Resistance ===================================================
    modifier.register_modifier(Const.mod_type_dmg_resistance, "energy", resistance_modifier_energy, -1);

    // == Skills ==============================================================
    modifier.register_modifier(Const.mod_type_skill, "stonecunning_search", skill_modifier_stonecunning_search, Const.skill_search as int);

}

