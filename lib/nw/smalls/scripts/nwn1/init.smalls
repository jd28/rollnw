    mfeat.add(Const.mfeat_spell_focus, Const.spell_school_necromancy, Const.feat_spell_focus_necromancy);
    mfeat.add(Const.mfeat_spell_focus, Const.spell_school_transmutation, Const.feat_spell_focus_transmutation);

    mfeat.add(Const.mfeat_spell_focus_greater, Const.spell_school_abjuration, Const.feat_greater_spell_focus_abjuration);
