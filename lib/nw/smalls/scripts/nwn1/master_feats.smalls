import core.creature as Cre;
import core.item as item;
from core.creature import { CreatureStats };

import nwn1.baseitems as baseitems;
import nwn1.constants as Const;

fn _base_item_for_attack(obj: Creature, attack_type: Const.AttackType): Const.BaseItemType {
    var weapon = Cre.weapon_for_attack(obj, attack_type);
    return Const.BaseItemType(item.get_baseitem_type(weapon) as int);
}

fn _favored_enemy_feat_for_race(race: Const.RacialType): Const.Feat {
    if (race == Const.racial_type_dwarf) { return Const.feat_favored_enemy_dwarf; }
    if (race == Const.racial_type_elf) { return Const.feat_favored_enemy_elf; }
    if (race == Const.racial_type_gnome) { return Const.feat_favored_enemy_gnome; }
    if (race == Const.racial_type_halfling) { return Const.feat_favored_enemy_halfling; }
    if (race == Const.racial_type_halfelf) { return Const.feat_favored_enemy_halfelf; }
    if (race == Const.racial_type_halforc) { return Const.feat_favored_enemy_halforc; }
    if (race == Const.racial_type_human) { return Const.feat_favored_enemy_human; }
    if (race == Const.racial_type_aberration) { return Const.feat_favored_enemy_aberration; }
    if (race == Const.racial_type_animal) { return Const.feat_favored_enemy_animal; }
    if (race == Const.racial_type_beast) { return Const.feat_favored_enemy_beast; }
    if (race == Const.racial_type_construct) { return Const.feat_favored_enemy_construct; }
    if (race == Const.racial_type_dragon) { return Const.feat_favored_enemy_dragon; }
    if (race == Const.racial_type_humanoid_goblinoid) { return Const.feat_favored_enemy_goblinoid; }
    if (race == Const.racial_type_humanoid_monstrous) { return Const.feat_favored_enemy_monstrous; }
    if (race == Const.racial_type_humanoid_orc) { return Const.feat_favored_enemy_orc; }
    if (race == Const.racial_type_humanoid_reptilian) { return Const.feat_favored_enemy_reptilian; }
    if (race == Const.racial_type_elemental) { return Const.feat_favored_enemy_elemental; }
    if (race == Const.racial_type_fey) { return Const.feat_favored_enemy_fey; }
    if (race == Const.racial_type_giant) { return Const.feat_favored_enemy_giant; }
    if (race == Const.racial_type_magical_beast) { return Const.feat_favored_enemy_magical_beast; }
    if (race == Const.racial_type_outsider) { return Const.feat_favored_enemy_outsider; }
    if (race == Const.racial_type_shapechanger) { return Const.feat_favored_enemy_shapechanger; }
    if (race == Const.racial_type_undead) { return Const.feat_favored_enemy_undead; }
    if (race == Const.racial_type_vermin) { return Const.feat_favored_enemy_vermin; }
    return Const.feat_type_invalid;
}

fn _skill_focus_feat(skill: Const.Skill): Const.Feat {
    if (skill == Const.skill_animal_empathy) { return Const.feat_skill_focus_animal_empathy; }
    if (skill == Const.skill_concentration) { return Const.feat_skill_focus_concentration; }
    if (skill == Const.skill_disable_trap) { return Const.feat_skill_focus_disable_trap; }
    if (skill == Const.skill_discipline) { return Const.feat_skill_focus_discipline; }
    if (skill == Const.skill_heal) { return Const.feat_skill_focus_heal; }
    if (skill == Const.skill_hide) { return Const.feat_skill_focus_hide; }
    if (skill == Const.skill_listen) { return Const.feat_skill_focus_listen; }
    if (skill == Const.skill_lore) { return Const.feat_skill_focus_lore; }
    if (skill == Const.skill_move_silently) { return Const.feat_skill_focus_move_silently; }
    if (skill == Const.skill_open_lock) { return Const.feat_skill_focus_open_lock; }
    if (skill == Const.skill_parry) { return Const.feat_skill_focus_parry; }
    if (skill == Const.skill_perform) { return Const.feat_skill_focus_perform; }
    if (skill == Const.skill_persuade) { return Const.feat_skill_focus_persuade; }
    if (skill == Const.skill_pick_pocket) { return Const.feat_skill_focus_pick_pocket; }
    if (skill == Const.skill_search) { return Const.feat_skill_focus_search; }
    if (skill == Const.skill_set_trap) { return Const.feat_skill_focus_set_trap; }
    if (skill == Const.skill_spellcraft) { return Const.feat_skill_focus_spellcraft; }
    if (skill == Const.skill_spot) { return Const.feat_skill_focus_spot; }
    if (skill == Const.skill_taunt) { return Const.feat_skill_focus_taunt; }
    if (skill == Const.skill_use_magic_device) { return Const.feat_skill_focus_use_magic_device; }
    if (skill == Const.skill_appraise) { return Const.feat_skill_focus_appraise; }
    if (skill == Const.skill_tumble) { return Const.feat_skill_focus_tumble; }
    if (skill == Const.skill_craft_trap) { return Const.feat_skill_focus_craft_trap; }
    if (skill == Const.skill_bluff) { return Const.feat_skill_focus_bluff; }
    if (skill == Const.skill_intimidate) { return Const.feat_skill_focus_intimidate; }
    if (skill == Const.skill_craft_armor) { return Const.feat_skill_focus_craft_armor; }
    if (skill == Const.skill_craft_weapon) { return Const.feat_skill_focus_craft_weapon; }
    return Const.feat_type_invalid;
}

