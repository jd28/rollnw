    if (skill == Const.skill_heal) { return Const.feat_epic_skill_focus_heal; }
    if (skill == Const.skill_hide) { return Const.feat_epic_skill_focus_hide; }
    if (skill == Const.skill_listen) { return Const.feat_epic_skill_focus_listen; }
    if (skill == Const.skill_lore) { return Const.feat_epic_skill_focus_lore; }
    if (skill == Const.skill_move_silently) { return Const.feat_epic_skill_focus_move_silently; }
    if (skill == Const.skill_open_lock) { return Const.feat_epic_skill_focus_open_lock; }
    if (skill == Const.skill_parry) { return Const.feat_epic_skill_focus_parry; }
    if (skill == Const.skill_perform) { return Const.feat_epic_skill_focus_perform; }
    if (skill == Const.skill_persuade) { return Const.feat_epic_skill_focus_persuade; }
    if (skill == Const.skill_pick_pocket) { return Const.feat_epic_skill_focus_pick_pocket; }
    if (skill == Const.skill_search) { return Const.feat_epic_skill_focus_search; }
    if (skill == Const.skill_set_trap) { return Const.feat_epic_skill_focus_set_trap; }
    if (skill == Const.skill_spellcraft) { return Const.feat_epic_skill_focus_spellcraft; }
    if (skill == Const.skill_spot) { return Const.feat_epic_skill_focus_spot; }
    if (skill == Const.skill_taunt) { return Const.feat_epic_skill_focus_taunt; }
    if (skill == Const.skill_use_magic_device) { return Const.feat_epic_skill_focus_use_magic_device; }
    if (skill == Const.skill_appraise) { return Const.feat_epic_skill_focus_appraise; }
    if (skill == Const.skill_tumble) { return Const.feat_epic_skill_focus_tumble; }
    if (skill == Const.skill_craft_trap) { return Const.feat_epic_skill_focus_craft_trap; }
    if (skill == Const.skill_bluff) { return Const.feat_epic_skill_focus_bluff; }
    if (skill == Const.skill_intimidate) { return Const.feat_epic_skill_focus_intimidate; }
    if (skill == Const.skill_craft_armor) { return Const.feat_epic_skill_focus_craft_armor; }
    if (skill == Const.skill_craft_weapon) { return Const.feat_epic_skill_focus_craft_weapon; }
    return Const.feat_type_invalid;
}

fn _spell_focus_feat(school: Const.SpellSchool): int {
    if (school == Const.spell_school_abjuration) { return Const.feat_spell_focus_abjuration as int; }
    if (school == Const.spell_school_conjuration) { return Const.feat_spell_focus_conjuration as int; }
    if (school == Const.spell_school_divination) { return Const.feat_spell_focus_divination as int; }
    if (school == Const.spell_school_enchantment) { return Const.feat_spell_focus_enchantment as int; }
    if (school == Const.spell_school_evocation) { return Const.feat_spell_focus_evocation as int; }
    if (school == Const.spell_school_illusion) { return Const.feat_spell_focus_illusion as int; }
    if (school == Const.spell_school_necromancy) { return Const.feat_spell_focus_necromancy as int; }
    if (school == Const.spell_school_transmutation) { return Const.feat_spell_focus_transmutation as int; }
    return -1;
}

fn _greater_spell_focus_feat(school: Const.SpellSchool): int {
    if (school == Const.spell_school_abjuration) { return Const.feat_greater_spell_focus_abjuration as int; }
    if (school == Const.spell_school_conjuration) { return Const.feat_greater_spell_focus_conjuration as int; }
    if (school == Const.spell_school_divination) { return Const.feat_greater_spell_focus_divination as int; }
    if (school == Const.spell_school_enchantment) { return Const.feat_greater_spell_focus_enchantment as int; }
    if (school == Const.spell_school_evocation) { return Const.feat_greater_spell_focus_evocation as int; }
    if (school == Const.spell_school_illusion) { return Const.feat_greater_spell_focus_illusion as int; }
    if (school == Const.spell_school_necromancy) { return Const.feat_greater_spell_focus_necromancy as int; }
    if (school == Const.spell_school_transmutation) { return Const.feat_greater_spell_focus_transmutation as int; }
    return -1;
}

fn _epic_spell_focus_feat(school: Const.SpellSchool): int {
    if (school == Const.spell_school_abjuration) { return Const.feat_epic_spell_focus_abjuration as int; }
    if (school == Const.spell_school_conjuration) { return Const.feat_epic_spell_focus_conjuration as int; }
    if (school == Const.spell_school_divination) { return Const.feat_epic_spell_focus_divination as int; }
    if (school == Const.spell_school_enchantment) { return Const.feat_epic_spell_focus_enchantment as int; }
    if (school == Const.spell_school_evocation) { return Const.feat_epic_spell_focus_evocation as int; }
    if (school == Const.spell_school_illusion) { return Const.feat_epic_spell_focus_illusion as int; }
    if (school == Const.spell_school_necromancy) { return Const.feat_epic_spell_focus_necromancy as int; }
    if (school == Const.spell_school_transmutation) { return Const.feat_epic_spell_focus_transmutation as int; }
    return -1;
}

fn skill_focus_bonus(obj: Creature, skill: Const.Skill): int {
    var result = 0;

    if (Cre.has_feat(obj, _skill_focus_feat(skill))) { result += 3; }
    if (Cre.has_feat(obj, _epic_skill_focus_feat(skill))) { result += 10; }

    return result;
}

fn spell_focus_bonus(obj: Creature, school: Const.SpellSchool): int {
    var result = 0;

    var spell_focus = _spell_focus_feat(school);
    if (spell_focus >= 0 && Cre.has_feat(obj, Const.Feat(spell_focus))) {
        result += 2;
    }

    var greater_spell_focus = _greater_spell_focus_feat(school);
    if (greater_spell_focus >= 0 && Cre.has_feat(obj, Const.Feat(greater_spell_focus))) {
        result += 2;
    }

    var epic_spell_focus = _epic_spell_focus_feat(school);
    if (epic_spell_focus >= 0 && Cre.has_feat(obj, Const.Feat(epic_spell_focus))) {
        result += 2;
    }

    return result;
}

fn attack_bonus_weapon_feat(obj: Creature, attack_type: Const.AttackType): int {
    if (attack_type == Const.attack_type_invalid || attack_type == Const.attack_type_any) {
        return 0;
    }

    var base_item = _base_item_for_attack(obj, attack_type);
    var result = 0;

    if ((base_item as int) < 0) {
        if (Cre.has_feat(obj, Const.feat_weapon_focus_unarmed)) {
            result += 1;
        }
        if (Cre.has_feat(obj, Const.feat_epic_weapon_focus_unarmed)) {
            result += 2;
        }
        return result;
    }

    var focus_feat = baseitems.weapon_focus_feat(base_item);
    if (focus_feat >= 0 && Cre.has_feat(obj, Const.Feat(focus_feat))) {
        result += 1;
    }

    var epic_focus_feat = baseitems.epic_weapon_focus_feat(base_item);
    if (epic_focus_feat >= 0 && Cre.has_feat(obj, Const.Feat(epic_focus_feat))) {
        result += 2;
    }

    return result;
}

fn attack_bonus_favored_enemy(obj: Creature, versus: object): int {
    if (!has_favored_enemy(obj, versus)) { return 0; }
    return Cre.has_feat(obj, Const.feat_epic_bane_of_enemies) ? 2 : 0;
}

fn has_favored_enemy(obj: Creature, versus: object): bool {
    if (!(versus is Creature)) { return false; }
    if (Cre.get_level_by_class(obj, Const.class_type_ranger) == 0) { return false; }

    var vs_stats = get_propset!(CreatureStats)(versus as Creature);
    var favored = _favored_enemy_feat_for_race(Const.RacialType(vs_stats.race));
    return favored != Const.feat_type_invalid && Cre.has_feat(obj, favored);
}

fn attack_bonus_weapon_master(obj: Creature, attack_type: Const.AttackType): int {
    var wm = Cre.get_level_by_class(obj, Const.class_type_weapon_master);
    if (wm < 5) {
        return 0;
    }

    var base_item = _base_item_for_attack(obj, attack_type);
    var has_choice = false;
    if ((base_item as int) >= 0) {
        var choice_feat = baseitems.weapon_of_choice_feat(base_item);
        has_choice = choice_feat >= 0 && Cre.has_feat(obj, Const.Feat(choice_feat));
    }

    if (!has_choice) { return 0; }

    var result = 1;
    if (wm >= 13) {
        result += (wm - 10) / 3;
    }
    return result;
}

fn has_improved_critical(obj: Creature, attack_type: Const.AttackType): bool {
    var base_item = _base_item_for_attack(obj, attack_type);
    if ((base_item as int) < 0) {
        return Cre.has_feat(obj, Const.feat_improved_critical_unarmed);
    }

    var improved_critical_feat = baseitems.weapon_improved_critical_feat(base_item);
    return improved_critical_feat >= 0 && Cre.has_feat(obj, Const.Feat(improved_critical_feat));
}

fn has_overwhelming_critical(obj: Creature, attack_type: Const.AttackType): bool {
    var base_item = _base_item_for_attack(obj, attack_type);
    if ((base_item as int) < 0) {
        return Cre.has_feat(obj, Const.feat_epic_overwhelming_critical_unarmed);
    }

    var overwhelming_critical_feat = baseitems.epic_weapon_overwhelming_critical_feat(base_item);
    return overwhelming_critical_feat >= 0
        && Cre.has_feat(obj, Const.Feat(overwhelming_critical_feat));
}

fn has_devastating_critical(obj: Creature, attack_type: Const.AttackType): bool {
    var base_item = _base_item_for_attack(obj, attack_type);
    if ((base_item as int) < 0) {
        return Cre.has_feat(obj, Const.feat_epic_devastating_critical_unarmed);
    }

    var devastating_critical_feat = baseitems.epic_weapon_devastating_critical_feat(base_item);
    return devastating_critical_feat >= 0
        && Cre.has_feat(obj, Const.Feat(devastating_critical_feat));
}

fn weapon_damage_specialization_bonus(obj: Creature, base_item: Const.BaseItemType): int {
    if ((base_item as int) < 0) {
        if (Cre.has_feat(obj, Const.feat_epic_weapon_specialization_unarmed)) {
            return 8;
        }
        if (Cre.has_feat(obj, Const.feat_weapon_specialization_unarmed)) {
            return 4;
        }
        return 0;
    }

    var epic_specialization_feat = baseitems.epic_weapon_specialization_feat(base_item);
    if (epic_specialization_feat >= 0
        && Cre.has_feat(obj, Const.Feat(epic_specialization_feat))) {
        return 8;
    }

    var specialization_feat = baseitems.weapon_specialization_feat(base_item);
    if (specialization_feat >= 0
        && Cre.has_feat(obj, Const.Feat(specialization_feat))) {
        return 4;
    }

    return 0;
}
