};

[[value_type]]
type SkillEntry {
    [[index]]
    id:                 int;
    name:               StrRef;
    untrained:          bool;
    ability:            int;    // 0=STR 1=DEX 2=CON 3=INT 4=WIS 5=CHA, -1=none
    armor_check_penalty:bool;
};
