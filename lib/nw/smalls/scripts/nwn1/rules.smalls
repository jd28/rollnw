[[value_type]]
type BaseItemEntry {
    [[index]]
    id:                                    int;
    name:                                  StrRef;
    model_type:                            int;
    item_class:                            T.ResRef;
    default_model:                         T.Resource;
    default_icon:                          T.ResRef;
    inventory_width:                       int;
    inventory_height:                      int;
    equipable_slots:                       int;
    base_cost:                             int;
    stack_size:                            int;
    cost_multiplier:                       float;
    req_feat0:                             int;
    req_feat1:                             int;
    req_feat2:                             int;
    req_feat3:                             int;
    req_feat4:                             int;
    base_ac:                               int;
    damage_num:                            int;
    damage_die:                            int;
    crit_threat:                           int;
    crit_multiplier:                       int;
    weapon_type:                           int;
    ranged:                                bool;
    weapon_size:                           int;
    weapon_focus_feat:                     int;
    epic_weapon_focus_feat:                int;
    weapon_specialization_feat:            int;
    epic_weapon_specialization_feat:       int;
    weapon_improved_critical_feat:         int;
    epic_weapon_overwhelming_critical_feat:int;
    epic_weapon_devastating_critical_feat: int;
    weapon_of_choice_feat:                 int;
};

[[value_type]]
type DoorTypeEntry {
    [[index]]
    id:    int;
    model: T.ResRef;
};

[[value_type]]
type GenericDoorEntry {
    [[index]]
    id:    int;
    model: T.ResRef;
};

[[value_type]]
type PlaceableEntry {
    [[index]]
    id:             int;
