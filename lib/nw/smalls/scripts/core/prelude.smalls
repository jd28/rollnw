[[native]] fn print(message: string);
[[native]] fn println(message: string);
[[native]] fn assert(cond: bool);
[[native]] fn error(message: string);
[[native]] fn panic(message: string);
[[native]] fn gc_collect();
[[intrinsic("get_propset")]] fn get_propset(obj: object): $T;
[[intrinsic("load_config")]] fn load_config(path: string): array!($T);
