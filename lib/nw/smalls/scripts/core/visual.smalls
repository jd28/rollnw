from core.types import { ResRef };

const visual_model_kind_root = 0;
const visual_model_kind_item_model = 1;
const visual_model_kind_creature_model_part = 2;
const visual_model_kind_creature_attachment = 3;
const visual_model_slot_none = -1;
const visual_model_flag_none = 0;
const visual_model_flag_requires_wearer = 1;
const visual_model_flag_hidden_in_game = 2;
const visual_model_flag_hidden_in_toolset = 4;

const visual_plt_layer_skin = 0;
const visual_plt_layer_hair = 1;
const visual_plt_layer_metal1 = 2;
const visual_plt_layer_metal2 = 3;
const visual_plt_layer_cloth1 = 4;
const visual_plt_layer_cloth2 = 5;
const visual_plt_layer_leather1 = 6;
const visual_plt_layer_leather2 = 7;
const visual_plt_layer_tattoo1 = 8;
const visual_plt_layer_tattoo2 = 9;

const visual_plt_mask_skin = 1;
const visual_plt_mask_hair = 2;
const visual_plt_mask_metal1 = 4;
const visual_plt_mask_metal2 = 8;
const visual_plt_mask_cloth1 = 16;
const visual_plt_mask_cloth2 = 32;
