type VisualModelRow {
    model: ResRef;
    attach_to: ResRef;
    attach_from: ResRef;
    kind: int;
    slot: int;
    part: int;
    source_part: int;
    model_part: int;
    flags: int;
};

type VisualLightRow {
    color: int;
    offset_x: float;
    offset_y: float;
    offset_z: float;
};

[[native]] fn clear_visual(obj: object, appearance: int): bool;

[[native]] fn clear_visual_slot(obj: object, slot: int): bool;

[[native]] fn set_visual_body_variant(obj: object, body_variant: int): bool;

[[native]] fn add_visual_model(
    obj: object,
    model: ResRef,
    attach_to: ResRef,
    attach_from: ResRef,
    kind: int,
    slot: int,
    part: int,
    flags: int): bool;

[[native]] fn add_visual_model_row(
    obj: object,
    model: ResRef,
    attach_to: ResRef,
    attach_from: ResRef,
    kind: int,
    slot: int,
    part: int,
    source_part: int,
    model_part: int,
    flags: int): bool;

[[native]] fn add_visual_part(
    obj: object,
    attach_to: ResRef,
    attach_from: ResRef,
    kind: int,
    slot: int,
    part: int,
    source_part: int,
    model_part: int,
    flags: int): bool;

[[native]] fn set_visual_plt_colors(
    obj: object,
    slot: int,
    kind: int,
    part: int,
    mask: int,
    skin: int,
    hair: int,
    metal1: int,
    metal2: int,
    cloth1: int,
    cloth2: int,
    leather1: int,
    leather2: int,
    tattoo1: int,
    tattoo2: int): bool;

[[native]] fn set_visual_base_plt_colors(
    obj: object,
    mask: int,
    skin: int,
    hair: int,
    metal1: int,
    metal2: int,
    cloth1: int,
    cloth2: int,
    leather1: int,
    leather2: int,
    tattoo1: int,
    tattoo2: int): bool;

[[native]] fn add_visual_light(
    obj: object,
    color: int,
    offset_x: float,
    offset_y: float,
    offset_z: float): bool;
