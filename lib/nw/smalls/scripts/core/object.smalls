import core.effects as Eff;

fn _invalid_object(): object {
    var o: object;
    return o;
}
const invalid: object = _invalid_object();

[[native]] fn apply_effect(obj: object, effect: Eff.Effect): bool;
[[native]] fn has_effect_applied(obj: object, effect: Eff.Effect): bool;
[[native]] fn remove_effect(obj: object, effect: Eff.Effect): bool;
[[native]] fn is_creature(obj: object): bool;
[[native]] fn is_pc(obj: object): bool;
