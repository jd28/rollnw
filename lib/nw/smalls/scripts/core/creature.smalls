[[native]] fn equip_item_in_slot(creature: Creature, item: Item, slot: EquipIndex): bool;
[[native]] fn get_equipped_item(creature: Creature, slot: EquipIndex): Item;
[[native]] fn unequip_item_in_slot(creature: Creature, slot: EquipIndex): Item;
[[native]] fn inventory_add_item(creature: Creature, item: Item): bool;
[[native]] fn inventory_remove_item(creature: Creature, item: Item): bool;

fn can_equip_item(creature: Creature, equipped: Item, slot: EquipIndex): bool {
    return item.can_equip_item(creature, equipped, slot);
}

fn equip_item(creature: Creature, equipped: Item, slot: EquipIndex): bool {
    if (equipped == Obj.invalid) {
        return false;
    }

    if (!can_equip_item(creature, equipped, slot)) {
        return false;
    }

    var current = get_equipped_item(creature, slot);

    if (current != Obj.invalid) {
        var old_item = unequip_item(creature, slot);
        if (old_item == Obj.invalid) {
            return false;
        }
    }

    if (!inventory_remove_item(creature, equipped)) {
        // Tolerate direct world/container equips for now.
    }

    if (!equip_item_in_slot(creature, equipped, slot)) {
        inventory_add_item(creature, equipped);
        return false;
    }

    item.process_item_properties(creature, equipped, slot, false);
    item._dispatch_on_equip(creature, equipped, slot);
    return true;
}

fn unequip_item(creature: Creature, slot: EquipIndex): Item {
    var removed = unequip_item_in_slot(creature, slot);
    if (removed == Obj.invalid) {
        return Obj.invalid as Item;
    }

    item.process_item_properties(creature, removed, slot, true);
    if (!inventory_add_item(creature, removed)) {
        // Fail-and-revert for now; future policy may drop to ground.
        if (equip_item_in_slot(creature, removed, slot)) {
            item.process_item_properties(creature, removed, slot, false);
        }
        return Obj.invalid as Item;
    }

    item._dispatch_on_unequip(creature, removed, slot);
    return removed;
}

