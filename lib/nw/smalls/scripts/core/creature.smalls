// Cold descriptive data and event scripts: loaded from UTC, rarely changes.
[[propset(Creature)]]
type CreatureDescriptor {
    on_attacked: ResRef;
    on_blocked: ResRef;
    on_conversation: ResRef;
    on_damaged: ResRef;
    on_death: ResRef;
    on_disturbed: ResRef;
    on_endround: ResRef;
    on_heartbeat: ResRef;
    on_perceived: ResRef;
    on_rested: ResRef;
    on_spawn: ResRef;
    on_spell_cast_at: ResRef;
    on_user_defined: ResRef;

    conversation: ResRef;
    description: TextRef;
    name_first: TextRef;
    name_last: TextRef;
    deity: string;
    subrace: string;
    soundset: int;
    decay_time: int;
};

// Authored visual source data. Smalls resolves this to flat native visual rows.
[[propset(Creature)]]
type CreatureAppearance {
    appearance: int;
    phenotype: int;
    tail: int;
    wings: int;
    portrait: ResRef;
    portrait_id: int;

    color_hair: int;
    color_skin: int;
    color_tattoo1: int;
    color_tattoo2: int;

    body_part_belt: int;
    body_part_bicep_left: int;
    body_part_bicep_right: int;
    body_part_foot_left: int;
    body_part_foot_right: int;
    body_part_forearm_left: int;
    body_part_forearm_right: int;
    body_part_hand_left: int;
    body_part_hand_right: int;
    body_part_head: int;
    body_part_neck: int;
    body_part_pelvis: int;
    body_part_shin_left: int;
    body_part_shin_right: int;
    body_part_shoulder_left: int;
    body_part_shoulder_right: int;
    body_part_thigh_left: int;
    body_part_thigh_right: int;
    body_part_torso: int;
};

fn get_appearance(obj: Creature): int {
    var appearance = get_propset!(CreatureAppearance)(obj);
    return appearance.appearance;
}

fn get_wings(obj: Creature): int {
    var appearance = get_propset!(CreatureAppearance)(obj);
    return appearance.wings;
}

fn get_tail(obj: Creature): int {
    var appearance = get_propset!(CreatureAppearance)(obj);
    return appearance.tail;
}

fn get_body_part(obj: Creature, part: int): int {
    var appearance = get_propset!(CreatureAppearance)(obj);
    if (part == body_part_belt) { return appearance.body_part_belt; }
    if (part == body_part_bicep_left) { return appearance.body_part_bicep_left; }
    if (part == body_part_bicep_right) { return appearance.body_part_bicep_right; }
    if (part == body_part_foot_left) { return appearance.body_part_foot_left; }
    if (part == body_part_foot_right) { return appearance.body_part_foot_right; }
    if (part == body_part_forearm_left) { return appearance.body_part_forearm_left; }
    if (part == body_part_forearm_right) { return appearance.body_part_forearm_right; }
    if (part == body_part_hand_left) { return appearance.body_part_hand_left; }
    if (part == body_part_hand_right) { return appearance.body_part_hand_right; }
    if (part == body_part_head) { return appearance.body_part_head; }
    if (part == body_part_neck) { return appearance.body_part_neck; }
    if (part == body_part_pelvis) { return appearance.body_part_pelvis; }
    if (part == body_part_shin_left) { return appearance.body_part_shin_left; }
    if (part == body_part_shin_right) { return appearance.body_part_shin_right; }
    if (part == body_part_shoulder_left) { return appearance.body_part_shoulder_left; }
    if (part == body_part_shoulder_right) { return appearance.body_part_shoulder_right; }
    if (part == body_part_thigh_left) { return appearance.body_part_thigh_left; }
    if (part == body_part_thigh_right) { return appearance.body_part_thigh_right; }
    if (part == body_part_torso) { return appearance.body_part_torso; }
    return 0;
}

// "What this creature is" — rarely changes, consulted by most RPG calculations
[[propset(Creature)]]
type CreatureStats {
    abilities: int[6];      // STR=0, DEX=1, CON=2, INT=3, WIS=4, CHA=5
    save_fort: int;
    save_reflex: int;
    save_will: int;
    skills: array!(int);    // indexed by Skill value
    feats: array!(int);     // Feat values
    race: int;
    gender: int;
    good_evil: int;         // 0=evil, 50=neutral, 100=good
    lawful_chaotic: int;    // 0=chaotic, 50=neutral, 100=lawful
    ac_natural_bonus: int;
    cr: float;
    cr_adjust: int;
    perception_range: int;
    disarmable: int;
    immortal: int;
    interruptable: int;
    lootable: int;
    pc: int;
    plot: int;
    chunk_death: int;
    bodybag: int;
    special_abilities: array!(SpecialAbility);
};

// Vital state — changes in combat, persisted to disk
[[propset(Creature)]]
type CreatureHealth {
    hp: int;
    hp_base_for_max: int;
    hp_current: int;
    hp_max: int;
    hp_temp: int;
    faction_id: int;
    starting_package: int;
};

// Class progression — changes on level-up, source of BAB and spell slots
[[propset(Creature)]]
type CreatureLevels {
    classes: int[8];        // Class IDs per slot
    class_levels: int[8];   // Level count per slot
    levelup_classes: array!(int); // Class slot per player level-up entry
    xp: int;
    walkrate: int;
};

fn get_total_levels(obj: Creature): int {
    var levels = get_propset!(CreatureLevels)(obj);
    var result = 0;
    for (var i = 0; i < 8; i += 1) {
        if (levels.class_levels[i] > 0) {
            result += levels.class_levels[i];
        }
    }
    return result;
}

fn progression_version(obj: Creature): int {
    const progression_mod = 1000003;
    var levels = get_propset!(CreatureLevels)(obj);
    var stats = get_propset!(CreatureStats)(obj);
    var v = arr.len(stats.feats) % progression_mod;

    for (var i = 0; i < 8; i += 1) {
        if (levels.classes[i] >= 0 && levels.class_levels[i] > 0) {
            var class_id = levels.classes[i] % 2048;
            var class_level = levels.class_levels[i] % 2048;
            v = ((v * 257) + (class_id * 31) + class_level) % progression_mod;
        }
    }
    return v;
}

fn get_level_by_class(obj: Creature, class_type: Class): int {
    var class_id = class_type as int;
    if (class_id < 0) {
        return 0;
    }

    var levels = get_propset!(CreatureLevels)(obj);
    for (var i = 0; i < 8; i += 1) {
        if (levels.classes[i] == class_id && levels.class_levels[i] > 0) {
            return levels.class_levels[i];
        }
    }
    return 0;
}

fn get_class_count(obj: Creature): int {
    var levels = get_propset!(CreatureLevels)(obj);
    var result = 0;
    for (var i = 0; i < 8; i += 1) {
        if (levels.classes[i] >= 0 && levels.class_levels[i] > 0) {
            result += 1;
        }
    }
    return result;
}

fn get_class_at(obj: Creature, index: int): Class {
    if (index < 0) {
        return Class(-1);
    }

    var levels = get_propset!(CreatureLevels)(obj);
    var current = 0;
    for (var i = 0; i < 8; i += 1) {
        if (levels.classes[i] >= 0 && levels.class_levels[i] > 0) {
            if (current == index) {
                return Class(levels.classes[i]);
            }
            current += 1;
        }
    }
    return Class(-1);
}

fn get_class_levels_at(obj: Creature, index: int): int {
    if (index < 0) {
        return 0;
    }

    var levels = get_propset!(CreatureLevels)(obj);
    var current = 0;
    for (var i = 0; i < 8; i += 1) {
        if (levels.classes[i] >= 0 && levels.class_levels[i] > 0) {
            if (current == index) {
                return levels.class_levels[i];
            }
            current += 1;
        }
    }
    return 0;
}

fn get_race(obj: Creature): int {
    var stats = get_propset!(CreatureStats)(obj);
    return stats.race;
}

fn get_gender(obj: Creature): int {
    var stats = get_propset!(CreatureStats)(obj);
    return stats.gender;
}

fn get_good_evil(obj: Creature): int {
    var stats = get_propset!(CreatureStats)(obj);
    return stats.good_evil;
}

fn get_lawful_chaotic(obj: Creature): int {
    var stats = get_propset!(CreatureStats)(obj);
    return stats.lawful_chaotic;
}

fn get_levelup_class_position(obj: Creature, level_index: int): int {
    if (level_index < 0) {
        return -1;
    }

    var levels = get_propset!(CreatureLevels)(obj);
    if (level_index >= arr.len(levels.levelup_classes)) {
        return -1;
    }
    return levels.levelup_classes[level_index];
}

fn _feat_lower_bound(feats: array!(int), needle: int): int {
    var lo = 0;
    var hi = arr.len(feats);
    for (lo < hi) {
        var mid = (lo + hi) / 2;
        if (feats[mid] < needle) {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    return lo;
}

fn _feat_upper_bound(feats: array!(int), needle: int): int {
    var lo = 0;
    var hi = arr.len(feats);
    for (lo < hi) {
        var mid = (lo + hi) / 2;
        if (feats[mid] <= needle) {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    return lo;
}

fn has_feat(obj: Creature, feat: Feat): bool {
    var stats = get_propset!(CreatureStats)(obj);
    var needle = feat as int;
    var index = _feat_lower_bound(stats.feats, needle);
    return index < arr.len(stats.feats) && stats.feats[index] == needle;
}

// Returns the highest feat in [start, stop] that obj has, or Feat(-1) if none.
fn highest_feat_in_range(obj: Creature, start: Feat, stop: Feat): Feat {
    var start_id = start as int;
    var stop_id = stop as int;
    if (stop_id < start_id) {
        return Feat(-1);
    }

    var stats = get_propset!(CreatureStats)(obj);
    var index = _feat_upper_bound(stats.feats, stop_id);
    if (index <= 0) {
        return Feat(-1);
    }

    var value = stats.feats[index - 1];
    return value >= start_id ? Feat(value) : Feat(-1);
}

// Returns the number of distinct known feats in [start, stop].
fn count_feats_in_range(obj: Creature, start: Feat, stop: Feat): int {
    var start_id = start as int;
    var stop_id = stop as int;
    if (stop_id < start_id) {
        return 0;
    }

    var stats = get_propset!(CreatureStats)(obj);
    var first = _feat_lower_bound(stats.feats, start_id);
    var last = _feat_upper_bound(stats.feats, stop_id);

    var result = 0;
    var previous = 0;
    var have_previous = false;
    for (var i = first; i < last; i += 1) {
        var current = stats.feats[i];
        if (!have_previous || current != previous) {
            result += 1;
            previous = current;
            have_previous = true;
        }
    }
    return result;
}

[[value_type]]
type CombatWeapon {
    ab_ability: int;     // attack bonus from ability score (STR, or DEX via weapon finesse)
    ab_mod: int;         // weapon attack bonus (enhancement/attack bonus IP + weapon feats)
    dmg_ability: int;    // damage bonus from ability score
    iter: int;           // iteration penalty factor
    power: int;          // weapon power for DR bypass
    base_dice: int;      // base weapon damage dice count
    base_sides: int;     // base weapon damage die sides
    base_bonus: int;     // base weapon damage bonus
    base_dmg_flags: int; // damage type bitmask (bludgeoning/piercing/slashing)
    crit_range: int;     // critical threat range
    crit_mult: int;      // critical multiplier
};

type CombatEpochKeys {
    effect_epoch: int;
    equip_epoch: int;
    progression_epoch: int;
    mode_epoch: int;
};

// Transient combat state — resets between sessions, not persisted
[[transient, propset(Creature)]]
type CreatureCombat {
    attack_current: int;
    attacks_onhand: int;
    attacks_offhand: int;
    attacks_extra: int;
    combat_mode: int;
    effect_epoch: int;
    equip_epoch: int;
    progression_epoch: int;
    ac_armor_base: int;
    ac_shield_base: int;
    size_ab_modifier: int;
    size_ac_modifier: int;
    target_distance_sq: float;
    target_state: int;
    hasted: int;
    size: int;
    // Unified slot cache: 0-15 offense/defense AB+AC+conceal, 16-27 per-round stable
    slot_valid_mask: int;          // 1 bit per slot indicating validity
    slot_values: int[32];          // cached aggregate value per slot
    // Offense context keys (stored on attacker, compared each sync)
    off_target: object;
    off_target_effect_epoch: int;
    off_effect_epoch: int;
    off_equip_epoch: int;
    off_mode_epoch: int;
    off_progression_epoch: int;    // tracks class progression changes
    // Cached attack_bonus_effect_delta_clamped(attacker, subtype, target)
    off_effect_delta_target: object;
    off_effect_delta_self_epoch: int;
    off_effect_delta_target_epoch: int;
    off_effect_delta_subtype: int;
    off_effect_delta_value: int;
    // Defense context keys (stored on target, compared each sync)
    def_self_effect_epoch: int;
    def_equip_epoch: int;
    def_progression_epoch: int;
    def_mode_epoch: int;
    def_target: object;
    def_target_effect_epoch: int;
    // Caller-set special attack request; consumed (cleared to 0) on resolution.
    // special_attack_ab is the AB modifier for that attack (e.g. -4 for knockdown).
    special_attack_request: int;
    special_attack_ab: int;
    // Defense-side per-round gates (Parry uses, Deflect Arrows once/round, Epic Dodge once/round).
    // Window keyed by current attacker and that attacker's round sequence start.
    defense_window_attacker: object;
    defense_window_seq: int;
    parry_uses: int;
    deflect_used: int;
    epic_dodge_used: int;
    // Cached full ability scores (with race + permanent modifiers + effects).
    // Invalidated when effect_epoch or progression_epoch changes.
    ability_cache_valid: bool;
    ability_cache_effect_epoch: int;
    ability_cache_progression_epoch: int;
    ability_scores: int[6];

    weapons: CombatWeapon[7];
};

// Combat cache - precomputed values for fast attack resolution.
// Invalidated when effect/progression/equip/mode epochs change.
[[transient, propset(Creature)]]
type CreatureCombatCache {
    // === OFFENSE ===
    ab_onhand: int;
    ab_offhand: int;
    ab_cweapon: int;
    ab_unarmed: int;
    ab_target: int;

    ab_nt_cache_valid: int;
    ab_nt_effect_epoch: int;
    ab_nt_progression_epoch: int;
    ab_nt_equip_epoch: int;
    ab_nt_mode_epoch: int;

    base_attack_bonus: int;
    feat_flags: int;
    dual_wield_penalty_on: int;
    dual_wield_penalty_off: int;
    monk_power_bonus: int;
    enchant_arrow_bonus: int;

    off_effect_epoch: int;
    off_progression_epoch: int;
    off_equip_epoch: int;
    off_mode_epoch: int;

    base_dice: int;
    base_sides: int;
    base_bonus: int;

    crit_threat: int;
    crit_mult: int;
    weapon_power: int;

    // === DEFENSE ===
    // Note: Best resistance/DR effects are queried fresh during combat
    // Cache is invalidated via defense_epoch when these effects change
    immune_slashing: int;
    immune_piercing: int;
    immune_bludgeoning: int;
    immune_fire: int;
    immune_cold: int;
    immune_electrical: int;
    immune_acid: int;
    immune_sonic: int;
    immune_divine: int;
    immune_magical: int;
    immune_positive: int;
    immune_negative: int;

    // === INVALIDATION EPOCHS ===
    effect_epoch: int;
    progression_epoch: int;
    equip_epoch: int;
    mode_epoch: int;
};
