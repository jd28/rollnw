#MAXMODEL ASCII
newmodel test_mtr_preserve_diffuse
setsupermodel test_mtr_preserve_diffuse NULL
setanimationscale 1
#MAXGEOM ASCII
beginmodelgeom test_mtr_preserve_diffuse
    node dummy test_mtr_preserve_diffuse
        parent NULL
    endnode
    node trimesh mesh01
        parent test_mtr_preserve_diffuse
        diffuse 1 1 1
        ambient 0 0 0
        specular 0 0 0
        shininess 4
        shadow 0
        beaming 0
        render 1
        transparencyhint 0
        bitmap preserved_diffuse
        materialname test_mtr_preserve_diffuse
        alpha 1
        scale 1
        selfillumcolor 0 0 0
        verts 3
            0 0 0
            1 0 0
            0 1 0
        faces 1
            0 1 2 1 0 1 2 1
        tverts 3
            0 0 0
            1 0 0
            0 1 0
    endnode
endmodelgeom test_mtr_preserve_diffuse
donemodel test_mtr_preserve_diffuse
