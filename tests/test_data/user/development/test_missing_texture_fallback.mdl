#MAXMODEL ASCII
newmodel test_missing_texture_fallback
setsupermodel test_missing_texture_fallback NULL
setanimationscale 1
#MAXGEOM ASCII
beginmodelgeom test_missing_texture_fallback
    node dummy test_missing_texture_fallback
        parent NULL
    endnode
    node trimesh mesh01
        parent test_missing_texture_fallback
        diffuse 1 1 1
        ambient 0 0 0
        specular 0 0 0
        shininess 4
        shadow 0
        beaming 0
        render 1
        transparencyhint 0
        bitmap zz_no_tex_fbk
        alpha 1
        scale 1
        selfillumcolor 0 0 0
        verts 3
            0 0 0
            1 0 0
            0 1 0
        faces 1
            0 1 2 1 0 1 2 1
        tverts 3
            0 0 0
            1 0 0
            0 1 0
    endnode
endmodelgeom test_missing_texture_fallback
donemodel test_missing_texture_fallback
