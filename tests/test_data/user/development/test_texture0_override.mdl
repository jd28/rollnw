#MAXMODEL ASCII
newmodel test_texture0_override
setsupermodel test_texture0_override NULL
setanimationscale 1
#MAXGEOM ASCII
beginmodelgeom test_texture0_override
    node dummy test_texture0_override
        parent NULL
    endnode
    node trimesh mesh01
        parent test_texture0_override
        diffuse 1 1 1
        ambient 0 0 0
        specular 0 0 0
        shininess 4
        shadow 0
        beaming 0
        render 1
        transparencyhint 0
        bitmap legacy_bitmap
        texture0 texture0_diffuse
        alpha 1
        scale 1
        selfillumcolor 0 0 0
        verts 3
            0 0 0
            1 0 0
            0 1 0
        faces 1
            0 1 2 1 0 1 2 1
        tverts 3
            0 0 0
            1 0 0
            0 1 0
    endnode
endmodelgeom test_texture0_override
donemodel test_texture0_override
