{
  "name": "vscode-smalls",
  "displayName": "Smalls",
  "description": "Smalls language support",
  "version": "0.0.1",
  "publisher": "rollnw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jd28/rollnw",
    "directory": "tools/vscode-smalls"
  },
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onLanguage:smalls"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "smalls",
        "aliases": [
          "Smalls",
          "smalls"
        ],
        "extensions": [
          ".smalls"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "smalls",
        "scopeName": "source.smalls",
        "path": "./syntaxes/smalls.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "smalls",
        "path": "./snippets/smalls.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Smalls configuration",
      "properties": {
        "smalls.lsp.path": {
          "type": "string",
          "default": "smalls-lsp",
          "description": "Path to the smalls-lsp executable"
        },
        "smalls.modulePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional module search paths"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run check-types && npm run bundle",
    "bundle": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js --sourcemap",
    "watch": "npm run bundle -- --watch",
    "check-types": "tsc -p ./ --noEmit"
  },
  "devDependencies": {
    "@types/node": "^18.14.6",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.10",
    "typescript": "^5.0.2"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
