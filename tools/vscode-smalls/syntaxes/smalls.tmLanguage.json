{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Smalls",
  "scopeName": "source.smalls",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.smalls",
          "match": "//.*$"
        },
        {
          "name": "comment.block.smalls",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.smalls",
          "begin": "\\[\\[",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.annotation.begin.smalls" }
          },
          "end": "\\]\\]",
          "endCaptures": {
            "0": { "name": "punctuation.definition.annotation.end.smalls" }
          },
          "patterns": [
            {
              "name": "entity.name.function.annotation.smalls",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.smalls",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.smalls",
              "match": "\\\\(n|t|r|\\\\|\"|0)"
            }
          ]
        },
        {
          "name": "string.quoted.double.fstring.smalls",
          "begin": "\\bf\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.smalls",
              "match": "\\\\(n|t|r|\\\\|\"|0)"
            },
            {
              "name": "meta.interpolation.smalls",
              "begin": "\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.smalls" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.smalls" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.smalls",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.smalls",
          "match": "\\b(?:fn|type|var|const|if|elif|else|for|in|return|switch|case|default|break|continue|import|from|as|is)\\b"
        },
        {
          "name": "constant.language.smalls",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.smalls",
          "match": "\\b(?:int|float|bool|string|void|object|vec3|Area|Creature|Item|Trigger|Placeable|Door|Waypoint|Encounter|Store|Sound|Player|Module)\\b"
        },
        {
          "name": "entity.name.type.generic.smalls",
          "match": "\\b(?:array|map)!\\b"
        },
        {
          "name": "variable.other.generic-parameter.smalls",
          "match": "\\$[A-Z]\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.smalls",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    }
  }
}
